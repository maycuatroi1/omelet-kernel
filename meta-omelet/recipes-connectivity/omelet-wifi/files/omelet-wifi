#!/usr/bin/env bash
# omelet-wifi — a friendly WiFi control CLI for the Omelet Pi 4 implant.
#
# A thin, colourful wrapper around nmcli (NetworkManager) so connecting to a
# network is "scan -> pick a number -> type the password". Run with no args for
# an interactive menu, or use the sub-commands for scripting.
#
#   omelet-wifi                 interactive menu
#   omelet-wifi connect [SSID] [PASS]   connect (prompts for what's missing)
#   omelet-wifi scan            list visible networks
#   omelet-wifi status          show current connection + IP
#   omelet-wifi list            show saved (known) networks
#   omelet-wifi forget <SSID>   delete a saved network
#   omelet-wifi disconnect      drop the current WiFi link
#   omelet-wifi on | off        turn the WiFi radio on/off
#
# Installed as both `omelet-wifi` and the short alias `wifi`.
set -uo pipefail

PROG="${0##*/}"

# ---- colours (auto-disabled when output is not a terminal) ----
if [ -t 1 ]; then
    R=$'\033[0m'; B=$'\033[1m'; D=$'\033[2m'
    GRN=$'\033[32m'; RED=$'\033[31m'; YEL=$'\033[33m'; CYN=$'\033[36m'
else
    R=; B=; D=; GRN=; RED=; YEL=; CYN=
fi

say()  { printf '%s\n' "$*"; }
ok()   { printf '%s\n' "${GRN}✓${R} $*"; }
warn() { printf '%s\n' "${YEL}!${R} $*"; }
err()  { printf '%s\n' "${RED}✗${R} $*" >&2; }
hdr()  { printf '\n%s\n' "${B}${CYN}$*${R}"; }

# ---- preconditions ------------------------------------------------------
require_nm() {
    if ! command -v nmcli >/dev/null 2>&1; then
        err "nmcli not found — NetworkManager is not installed."; exit 1
    fi
    # `nmcli general status` exits non-zero (and prints "NetworkManager is not
    # running") when the daemon is down — use that as the liveness probe.
    if ! nmcli general status >/dev/null 2>&1; then
        warn "NetworkManager isn't running — starting it…"
        systemctl start NetworkManager 2>/dev/null || true
        sleep 2
    fi
}

wifi_dev() {
    nmcli -t -f DEVICE,TYPE device status 2>/dev/null \
        | awk -F: '$2=="wifi"{print $1; exit}'
}

ensure_radio() {
    if [ "$(nmcli -t radio wifi 2>/dev/null)" != "enabled" ]; then
        warn "WiFi radio is off — enabling…"
        nmcli radio wifi on; sleep 1
    fi
}

# nmcli -t escapes ':' inside values as '\:' — turn it back for display/use.
unesc() { local s=${1//\\:/:}; printf '%s' "${s//\\\\/\\}"; }

signal_bar() {           # $1 = 0..100  -> coloured [####------] NN%
    local sig=${1:-0} n=$(( (${1:-0} + 9) / 10 )) bar="" i col
    (( n > 10 )) && n=10; (( n < 0 )) && n=0
    for ((i = 0; i < 10; i++)); do (( i < n )) && bar+="#" || bar+="-"; done
    if   (( sig >= 66 )); then col=$GRN
    elif (( sig >= 33 )); then col=$YEL
    else col=$RED; fi
    printf '%s[%s]%s %3d%%' "$col" "$bar" "$R" "$sig"
}

# ---- commands -----------------------------------------------------------
cmd_status() {
    require_nm
    local dev; dev=$(wifi_dev)
    hdr "WiFi status"
    if [ -z "$dev" ]; then err "No WiFi interface found."; return 1; fi
    local state conn ip4 gw
    state=$(nmcli -t -f GENERAL.STATE     device show "$dev" 2>/dev/null | cut -d: -f2-)
    conn=$( nmcli -t -f GENERAL.CONNECTION device show "$dev" 2>/dev/null | cut -d: -f2-)
    ip4=$(  nmcli -t -f IP4.ADDRESS        device show "$dev" 2>/dev/null | cut -d: -f2- | head -n1)
    gw=$(   nmcli -t -f IP4.GATEWAY        device show "$dev" 2>/dev/null | cut -d: -f2-)
    printf '  %-12s %s\n' "Interface:" "$dev"
    if [ -n "$conn" ] && [ "$conn" != "--" ]; then
        printf '  %-12s %s%s%s\n' "Network:"  "$GRN" "$conn" "$R"
        printf '  %-12s %s\n' "IP:"        "${ip4:-—}"
        printf '  %-12s %s\n' "Gateway:"   "${gw:-—}"
    else
        printf '  %-12s %snot connected%s\n' "Network:" "$YEL" "$R"
    fi
    printf '  %-12s %s\n' "State:" "${state:-unknown}"
}

cmd_scan() {             # populate SSIDS/SIGS/SECS arrays; print table unless $1=quiet
    require_nm; ensure_radio
    [ "${1:-}" = quiet ] || say "${D}Scanning…${R}"
    nmcli device wifi rescan 2>/dev/null; sleep 2
    SSIDS=(); SIGS=(); SECS=()
    local key val ssid sig sec
    declare -A seen=()
    while IFS= read -r line; do
        key=${line%%:*}; val=$(unesc "${line#*:}")
        case "$key" in
            SSID)     ssid=$val ;;
            SIGNAL)   sig=$val ;;
            SECURITY)
                sec=$val
                # record at end of each AP block (SECURITY is the last field)
                if [ -n "${ssid:-}" ] && [ -z "${seen[$ssid]:-}" ]; then
                    seen[$ssid]=1
                    SSIDS+=("$ssid"); SIGS+=("${sig:-0}"); SECS+=("$sec")
                fi
                ssid=""; sig=""; sec="" ;;
        esac
    done < <(nmcli -t -m multiline -f SSID,SIGNAL,SECURITY device wifi list 2>/dev/null)

    [ "${1:-}" = quiet ] && return 0
    hdr "Networks in range"
    if [ "${#SSIDS[@]}" -eq 0 ]; then warn "No networks found."; return 0; fi
    printf '  %s%3s  %-30s %-18s %s%s\n' "$B" "#" "SSID" "Signal" "Security" "$R"
    local i
    for i in "${!SSIDS[@]}"; do
        printf '  %3d  %-30s %-28s %s\n' \
            $((i + 1)) "${SSIDS[i]}" "$(signal_bar "${SIGS[i]}")" \
            "${SECS[i]:-${YEL}open${R}}"
    done
}

# connect <ssid> [password] [hidden]
cmd_connect() {
    require_nm; ensure_radio
    local dev ssid="${1:-}" pass="${2:-}" hidden="${3:-}"

    if [ -z "$ssid" ]; then          # interactive pick
        cmd_scan
        [ "${#SSIDS[@]}" -eq 0 ] && return 1
        printf '\n%s\n' "  ${D}0 = hidden network (type SSID by hand)${R}"
        local choice
        read -rp "${B}Pick a network #:${R} " choice
        if [ "$choice" = 0 ]; then
            read -rp "SSID: " ssid; hidden="hidden"
        elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#SSIDS[@]} )); then
            ssid="${SSIDS[choice-1]}"
            [ -z "${SECS[choice-1]}" ] && pass="--open"   # open network, no prompt
        else
            err "Invalid choice."; return 1
        fi
    fi

    if [ "$pass" = "--open" ]; then
        pass=""
    elif [ -z "$pass" ]; then
        read -rsp "Password for \"${ssid}\" (empty = open network): " pass; echo
    fi

    dev=$(wifi_dev)
    local args=(device wifi connect "$ssid")
    [ -n "$pass" ] && args+=(password "$pass")
    [ "$hidden" = hidden ] && args+=(hidden yes)
    [ -n "$dev" ] && args+=(ifname "$dev")

    say "${D}Connecting to ${ssid}…${R}"
    if nmcli "${args[@]}"; then
        ok "Connected to ${B}${ssid}${R} (saved — will auto-reconnect on boot)"
        cmd_status
    else
        err "Could not connect to \"${ssid}\" — wrong password or out of range?"
        return 1
    fi
}

cmd_list() {
    require_nm
    hdr "Saved networks"
    local active; active=$(nmcli -t -f NAME connection show --active 2>/dev/null)
    local found=0 name
    while IFS= read -r name; do
        [ -z "$name" ] && continue
        found=1
        if grep -qxF "$name" <<<"$active"; then
            printf '  %s* %s%s  %s(connected)%s\n' "$GRN" "$name" "$R" "$D" "$R"
        else
            printf '    %s\n' "$name"
        fi
    done < <(nmcli -t -f NAME,TYPE connection show 2>/dev/null \
                | awk -F: '$2 ~ /wireless/{print $1}')
    [ "$found" = 0 ] && warn "No saved networks yet."
}

cmd_forget() {
    require_nm
    local name="${1:-}"
    [ -z "$name" ] && { err "Usage: $PROG forget <SSID>"; return 1; }
    if nmcli connection delete "$name" 2>/dev/null; then
        ok "Forgot \"${name}\"."
    else
        err "No saved network named \"${name}\"."; return 1
    fi
}

cmd_disconnect() {
    require_nm
    local dev; dev=$(wifi_dev)
    [ -z "$dev" ] && { err "No WiFi interface."; return 1; }
    if nmcli device disconnect "$dev" >/dev/null 2>&1; then
        ok "Disconnected ${dev}."
    else
        warn "${dev} was not connected."
    fi
}

cmd_radio() {            # $1 = on|off
    require_nm
    nmcli radio wifi "$1" && ok "WiFi radio turned ${B}$1${R}."
}

usage() {
    cat <<EOF
${B}${CYN}omelet-wifi${R} — friendly WiFi control

  ${B}$PROG${R}                       interactive menu
  ${B}$PROG${R} connect [SSID] [PASS] connect (asks for anything missing)
  ${B}$PROG${R} scan                  list networks in range
  ${B}$PROG${R} status                show current link + IP
  ${B}$PROG${R} list                  show saved networks
  ${B}$PROG${R} forget <SSID>         delete a saved network
  ${B}$PROG${R} disconnect            drop the current WiFi link
  ${B}$PROG${R} on | off              radio power

Tip: ${D}nmtui${R} is also installed for a full ncurses interface.
EOF
}

menu() {
    require_nm
    while true; do
        hdr "Omelet WiFi"
        cmd_status
        cat <<EOF

  ${B}1${R}  Connect to a network
  ${B}2${R}  Saved networks
  ${B}3${R}  Disconnect
  ${B}4${R}  Turn WiFi off
  ${B}5${R}  Turn WiFi on
  ${B}q${R}  Quit
EOF
        local c; read -rp "${B}Choice:${R} " c
        case "$c" in
            1) cmd_connect ;;
            2) cmd_list ;;
            3) cmd_disconnect ;;
            4) cmd_radio off ;;
            5) cmd_radio on ;;
            q|Q|"") break ;;
            *) err "Unknown choice: $c" ;;
        esac
    done
}

# ---- dispatch -----------------------------------------------------------
case "${1:-menu}" in
    menu|"")            menu ;;
    connect|c)          shift; cmd_connect "$@" ;;
    scan|s|list-aps)    cmd_scan ;;
    status|st)          cmd_status ;;
    list|saved)         cmd_list ;;
    forget|rm|delete)   shift; cmd_forget "$@" ;;
    disconnect|down|dc) cmd_disconnect ;;
    on)                 cmd_radio on ;;
    off)                cmd_radio off ;;
    help|-h|--help)     usage ;;
    *)                  err "Unknown command: $1"; echo; usage; exit 1 ;;
esac
